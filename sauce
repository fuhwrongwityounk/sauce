local function onCharacterChildAdded(child)
    if not AntiStunEnabled then return end
    if child.Name == "Stun" or child.Name == "Slow" or child.Name == "Weight" or child.Name == "WeaveStun" then
        task.defer(function() child:Destroy() end)
    end
end

local function updateLocalCache(char)
    LocalCharacter = char
    LocalHumanoid = char:WaitForChild("Humanoid", 10)
    LocalRoot = char:WaitForChild("HumanoidRootPart", 10)

    if StunConnection then StunConnection:Disconnect() end
    StunConnection = char.ChildAdded:Connect(onCharacterChildAdded)
    
    if LocalHumanoid then
        LocalHumanoid.WalkSpeed = WalkSpeed 
        
        -- Permanent WalkSpeed connection 
        LocalHumanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if WS_Protection and not isTriggerHeld and LocalHumanoid.WalkSpeed ~= WalkSpeed then
                LocalHumanoid.WalkSpeed = WalkSpeed
            end
        end)
    end
end

LocalPlayer.CharacterAdded:Connect(updateLocalCache)
if LocalPlayer.Character then updateLocalCache(LocalPlayer.Character) end

