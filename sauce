Players.PlayerRemoving:Connect(function(leavingPlayer)
    if originalHRPProps[leavingPlayer] then
        originalHRPProps[leavingPlayer] = nil
    end
end)

local function resetHRP(targetPlayer, char)
    local props = originalHRPProps[targetPlayer]
    if props and char then
        local Root = char:FindFirstChild("HumanoidRootPart")
        if Root then
            if Root.Size ~= props.Size then Root.Size = props.Size end
            if Root.Transparency ~= props.Transparency then Root.Transparency = props.Transparency end
            if Root.CanCollide ~= props.CanCollide then Root.CanCollide = props.CanCollide end
            if Root.Color ~= props.Color then Root.Color = props.Color end
            Root.CanTouch = true
            Root.CanQuery = true
            
            local shell = Root:FindFirstChild("SolidShell")
            if shell then shell:Destroy() end
        end
    end
end

local function updateHitbox(targetPlayer, liveFolder)
    if targetPlayer == LocalPlayer then return end
    
    local char = targetPlayer.Character
    if not char then return end
    
    local Root = char:FindFirstChild("HumanoidRootPart")
    local Hum = char:FindFirstChild("Humanoid")
    if not Root or not Hum then return end

    local isKnocked = Hum.Health <= 0
    if not isKnocked and liveFolder then
        local entry = liveFolder:FindFirstChild(targetPlayer.Name)
        if entry then
            local knockedVal = entry:FindFirstChild("Knocked")
            if knockedVal and knockedVal.Value == true then
                isKnocked = true
            end
        end
    end

    local shouldApplyHitbox = (not isKnocked or HitGroundedEnabled)

    -- Solid Shell Logic
    local shell = Root:FindFirstChild("SolidShell")
    if SolidShellEnabled and shouldApplyHitbox then
        if not shell then
            shell = Instance.new("Part", Root)
            shell.Name = "SolidShell"
            shell.Transparency = 1
            shell.CanCollide = true 
            shell.Massless = true
        end
        shell.Size = Vector3.new(SolidShellSize, SolidShellSize, SolidShellSize)
        shell.CFrame = Root.CFrame
    else
        if shell then shell:Destroy() end
    end

    -- Hitbox Logic
    if shouldApplyHitbox and TargetHitboxSize > 2 then
        if not originalHRPProps[targetPlayer] then
            originalHRPProps[targetPlayer] = {
                Size = Root.Size,
                Transparency = Root.Transparency,
                CanCollide = Root.CanCollide,
                Color = Root.Color 
            }
        end

        if Root.Size ~= HitboxVector then Root.Size = HitboxVector end
        if Root.Transparency ~= HitboxTransparency then Root.Transparency = HitboxTransparency end
        if Root.Color ~= BlackColor then Root.Color = BlackColor end
        
        if Root.CanCollide then Root.CanCollide = false end
        if not Root.CanTouch then Root.CanTouch = true end
        if not Root.CanQuery then Root.CanQuery = true end
    else
        resetHRP(targetPlayer, char)
    end
end

local liveFolder = workspace:FindFirstChild("Live")
workspace.ChildAdded:Connect(function(c) if c.Name == "Live" then liveFolder = c end end)

local lastHitboxUpdate = 0
local hitboxUpdateRate = 0.08

RunService.Heartbeat:Connect(function(dt)
    lastHitboxUpdate = lastHitboxUpdate + dt
    if lastHitboxUpdate >= hitboxUpdateRate then
        lastHitboxUpdate = 0
        local allPlayers = Players:GetPlayers()
        for i = 1, #allPlayers do
            updateHitbox(allPlayers[i], liveFolder)
        end
    end
end)

